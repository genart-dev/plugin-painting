        "style": "fluid",
        "seed": 42
      }
    },
    {
      "id": "stipple-depth",
      "type": "painting:fill",
      "name": "Stipple tonal depth from wave value map",
      "visible": true,
      "locked": false,
      "opacity": 0.45,
      "blendMode": "multiply",
      "transform": { "x": 0, "y": 0, "width": 800, "height": 800, "rotation": 0, "scaleX": 1, "scaleY": 1, "anchorX": 0, "anchorY": 0 },
      "properties": {
        "strategy": "{\"type\":\"stipple\",\"density\":45,\"distribution\":\"poisson\"}",
        "shading": "{\"type\":\"algorithm\",\"channel\":\"valueMap\",\"range\":[0.0,1.0]}",
        "shadingAffects": "[\"density\",\"weight\"]",
        "color": "#0a1a2a",
        "size": 2.2,
        "seed": 99
      }
    }
  ]
}