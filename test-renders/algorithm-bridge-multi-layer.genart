  "dataChannels": [
    { "name": "flowField", "type": "vector", "cols": 50, "rows": 50 }
  ],
  "algorithm": "function sketch(ctx, state) {\n  var W = ctx.canvas.width, H = ctx.canvas.height;\n  var cols = 50, rows = 50;\n  var seed = state.seed || 77;\n\n  // Lissajous-derived flow field: two coupled oscillations create\n  // looping, spiraling flow patterns impossible with noise alone.\n  var flowField = new Float32Array(cols * rows * 3);\n\n  for (var row = 0; row < rows; row++) {\n    for (var col = 0; col < cols; col++) {\n      var nx = col / (cols - 1);\n      var ny = row / (rows - 1);\n      // Map to [-2, 2] centered coordinates\n      var cx = (nx - 0.5) * 4;\n      var cy = (ny - 0.5) * 4;\n\n      // Two coupled Lissajous-like angle fields\n      var a1 = Math.sin(cx * 1.7 + cy * 0.9) * Math.cos(cy * 1.3 - cx * 0.5);\n      var a2 = Math.cos(cx * 0.8 + cy * 2.1) * Math.sin(cy * 0.6 + cx * 1.5);\n      var angle = Math.atan2(a1 + a2, a1 - a2);\n\n      // Magnitude: strong in center, fading at edges\n      var edgeDist = Math.min(nx, ny, 1 - nx, 1 - ny);\n      var mag = Math.min(1, edgeDist * 6) * (0.5 + 0.5 * Math.abs(Math.sin(a1 * 2)));\n\n      var idx = (row * cols + col) * 3;\n      flowField[idx]     = Math.cos(angle);\n      flowField[idx + 1] = Math.sin(angle);\n      flowField[idx + 2] = mag;\n    }\n  }\n\n  if (typeof window !== 'undefined' && window.__genart_data) {\n    window.__genart_data.flowField = flowField;\n    window.__genart_data.cols = cols;\n    window.__genart_data.rows = rows;\n  }\n\n  ctx.fillStyle = '#f5f0e8';\n  ctx.fillRect(0, 0, W, H);\n  return {};\n}\n",
